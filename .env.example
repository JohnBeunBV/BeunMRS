# ─────────────────────────────────────────────────────────────
# Environment template — copy to .env and fill in all values.
# NEVER commit .env to version control.
# In production all values are injected via Portainer secrets /
# GitHub Actions environment variables.
# ─────────────────────────────────────────────────────────────

# ── Versions ─────────────────────────────────────────────────
OPENMRS_VERSION=nightly          # pin to a specific tag in production

# ── OpenMRS DB ───────────────────────────────────────────────
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_USER=openmrs
OPENMRS_DB_PASSWORD=CHANGE_ME
OPENMRS_DB_ROOT_PASSWORD=CHANGE_ME

# ── OpenMRS app ──────────────────────────────────────────────
OPENMRS_PORT=8080
OPENMRS_API_USER=admin
OPENMRS_API_PASSWORD=CHANGE_ME

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_VHOST=openmrs
RABBITMQ_MANAGEMENT_PORT=15672   # set to 127.0.0.1:15672 or remove in production

# ── Notification service ──────────────────────────────────────
NOTIFICATION_PORT=3000
NOTIFICATION_DB_NAME=notifications
NOTIFICATION_DB_USER=notify
NOTIFICATION_DB_PASSWORD=CHANGE_ME

# ── Container image (set by CI, override locally for dev) ────
REGISTRY=ghcr.io
IMAGE_OWNER=your-github-org
IMAGE_TAG=latest

# ── Runtime ──────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info
