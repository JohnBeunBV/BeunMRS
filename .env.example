# ─────────────────────────────────────────────────────────────
# BeunMRS - Consolidated Environment Configuration Template
# Copy this file to '.env' and adjust values for local execution.
# NEVER commit the active '.env' file to version control.
# ─────────────────────────────────────────────────────────────

# ── Container Image Registry & Tags ──────────────────────────
REGISTRY=ghcr.io
IMAGE_OWNER=JohnBeunBV
IMAGE_TAG=latest

# ── Runtime Environment ──────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
STUDENT_GROUP=group-1

# ── OpenMRS Local Stack (Used in Full Sandbox Mode Only) ─────
OPENMRS_TAG=qa
OPENMRS_PORT=80
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_USER=openmrs
OPENMRS_DB_PASSWORD=openmrs_secure_pass
OPENMRS_DB_ROOT_PASSWORD=openmrs_root_secure_pass
OPENMRS_ADMIN_USER=admin
OPENMRS_ADMIN_PASSWORD=Admin1234

# ── RabbitMQ Message Broker ──────────────────────────────────
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=rabbit_secure_token
RABBITMQ_VHOST=openmrs
RABBITMQ_MANAGEMENT_PORT=15672

# ── SaaS Notification Database (PostgreSQL) ──────────────────
NOTIFICATION_DB_NAME=notifications
NOTIFICATION_DB_USER=notify
NOTIFICATION_DB_PASSWORD=notify_secure_password

# ── SaaS Application Gateways & Ports ────────────────────────
NOTIFICATION_PORT=4000
FRONTEND_PORT=3001

# ── FakeComWorld Mock Messaging Engine Credentials ───────────
SWIFTSEND_API_KEY=swiftsend_crypto_key_abc123
SECUREPOST_CLIENT_ID=securepost-client-id-prod
SECUREPOST_CLIENT_SECRET=securepost-client-secret-key-xyz
SECUREPOST_JWT_SECRET=securepost-jwt-secret-key-must-be-32-chars-long
LEGACYLINK_USERNAME=legacylink-soap-user
LEGACYLINK_PASSWORD=legacylink-soap-secure-password
ASYNCFLOW_API_KEY=asyncflow_token_key_7890

# ── Observability Dashboards ─────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secure_dashboard_pass
GRAFANA_PORT=3000