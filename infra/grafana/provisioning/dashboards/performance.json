{
  "title": "BeunMRS — Performance & Betrouwbaarheid",
  "uid": "beunmrs-perf",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Notificaties verstuurd / min (per provider)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(notifications_sent_total[1m]) * 60",
          "legendFormat": "✓ {{provider}} ({{tenant}})"
        },
        {
          "expr": "rate(notifications_failed_total[1m]) * 60",
          "legendFormat": "✗ {{provider}} ({{tenant}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 2,
      "title": "Provider call latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(provider_call_duration_seconds_bucket[2m]))",
          "legendFormat": "p50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(provider_call_duration_seconds_bucket[2m]))",
          "legendFormat": "p95 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(provider_call_duration_seconds_bucket[2m]))",
          "legendFormat": "p99 {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Foutpercentage notificaties (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(notifications_failed_total[5m])) / (sum(rate(notifications_sent_total[5m])) + sum(rate(notifications_failed_total[5m])) + 0.001)",
          "legendFormat": "Error rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Pending reminders (queue-diepte)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "scheduled_notifications_pending", "legendFormat": "Pending reminders" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Gefaalde notificaties (wachten op retry)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "notification_log_failed", "legendFormat": "Failed (awaiting retry)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "Outbox events pending (RabbitMQ buffer)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "outbox_events_pending", "legendFormat": "Outbox pending" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 7,
      "title": "Reminders dispatched per type (24h / 1h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(reminders_dispatched_total{status=\"sent\"}[2m]) * 60",
          "legendFormat": "Verstuurd ({{type}})"
        },
        {
          "expr": "rate(reminders_dispatched_total{status=\"skipped\"}[2m]) * 60",
          "legendFormat": "Overgeslagen ({{type}})"
        },
        {
          "expr": "rate(reminders_dispatched_total{status=\"error\"}[2m]) * 60",
          "legendFormat": "Fout ({{type}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Retry job uitkomsten",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(retry_attempts_total[5m]) * 60",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "title": "Reminder batch verwerkingstijd (p95)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(reminder_batch_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 batch duration"
        },
        {
          "expr": "histogram_quantile(0.50, rate(reminder_batch_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 batch duration"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "title": "Totaal notificaties verstuurd (cumulatief)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(notifications_sent_total)", "legendFormat": "Totaal verstuurd" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 11,
      "title": "Totaal permanent mislukt",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(retry_attempts_total{outcome=\"permanently_failed\"})",
          "legendFormat": "Permanent mislukt"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    }
  ]
}
